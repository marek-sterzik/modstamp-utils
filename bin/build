#!/bin/bash

set -e

build_dir="build"
binaries=(modstamp-server modstamp-client)

app_tmp_bin="modstamp-server.phar"
app_bin="modstamp-server"

cd "`dirname "$0"`/.."

if [ ! -d "$build_dir" ]; then
    mkdir "$build_dir"
fi

composer install --no-dev --no-interaction

cd "$build_dir"

for binary in "${binaries[@]}"; do
    tmp_binary="$binary.phar"
    rm -f "$binary" "$tmp_binary"
    php -d phar.readonly=0 ../lib/create-archive "$binary"
    mv "$tmp_binary" "$binary"
    chmod +x "$binary"
done
